# Flask configuration
FLASK_SECRET_KEY=supersecretkeyreplaceinproduction12345
FLASK_ENV=development

# Google Gemini API Configuration
# Get your key from https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Database Configuration (Defaults to SQLite in database/hirewise.db)
DATABASE_URL=sqlite:///database/hirewise.db

# Whisper Configuration
# Options: tiny, base, small (tiny is recommended for standard local machines)
WHISPER_MODEL_NAME=tiny
